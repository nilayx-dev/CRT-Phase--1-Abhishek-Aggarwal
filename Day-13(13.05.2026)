//Problem 1--
//Binary string without consequtive ones

#include<iostream>
using namespace std;

int consecutiveOnes(int n){
    //Base condition
    if(n==1){
        return 2;
    }
    if(n==2){
        return 3;
    }
    if(n==3){
        return 5;
    }
    //logic
     return consecutiveOnes(n-1)+consecutiveOnes(n-2);
}

int main(){
    cout<< consecutiveOnes(4);
    return 0;
}


//Problem--2
//Tiling Problem

#include<iostream>
using namespace std;
int tilingProblem(int n){
    if(n<=3){
        return 1;
    }
    return tilingProblem(n-1)+tilingProblem(n-4);
}

int main(){
    cout<<tilingProblem(5);
    return 0;
}

class Solution {
public:
int robForm(vector<int>& nums,int index){
    //base condition
if(index>=nums.size()){
    return 0;
}
    //logic
    int include=nums[index]+robForm(nums,index+2);
    int exclude=robForm(nums,index+1);

    return max(include,exclude);
}
    int rob(vector<int>& nums) {
        return robForm(nums,0);
    }
};
