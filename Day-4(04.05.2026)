//Problem --6
//Print hollow square

#include<iostream>
using namespace std;
int main(){
    for(int i=1;i<=5;i++){
       for(int j=1;j<=5;j++){
            cout<< " ";
            if(i==1 || j==1 || i==5 || j==5){
                cout<<"*";
            }else{
                cout<< " ";
            }
        }
        cout<<"\n";
    }
}

//Problem 7 --
//Print a pyramid

#include<iostream>
using namespace std;
int main(){

    for(int i=1;i<=6;i++){
        for(int j=6-i;j>=1;j--){
            cout << " ";
        }
        for(int k=1;k<=i;k++){
            cout<< " *";
        }
        cout<< "\n";
    }
}
