//Problem 4 --
//Print mirror  right angled triangle

#include<iostream>
using namespace std;
int main() {
	int n;
	cin>> n;
	
	for(int i=1; i<=n; i++) {
		for(int j=n-i; j>=1; j--) {
			cout << " ";
		}
		for(int k=1; k<=i; k++) {
			cout<< "*";
		}
		cout<<"\n";

	}
	return 0;
}


