//Problem 1 --
//Print 1 to 10 ,10 number of times

#include<iostream>
using namespace std;
int main(){
    //number of times to print the pattern
    for(int i=1;i<=10;i++){
        //what to print in the pattern
        for(int j=1;j<=10;j++){
            cout << j <<" ";
        }
        cout<< "\n";
    }
    return 0;
}

//Problem 2 --
//Print square pattern 

#include<iostream>
using namespace std;
int main(){
    //number of times to print the pattern
    for(int i=1;i<=10;i++){
        //what to print in the pattern
        for(int j=1;j<=10;j++){
            cout << "*";
        }
        cout<< "\n";
    }
    return 0;
}

//Problem 3 --
//Print right angled triangle 

#include<iostream>
using namespace std;
int main(){
    int n;
    cin>> n;

    for(int i=1;i<=n;i++){
        for(int j=1;j<=i;j++){
            cout << "*";
        }
        cout<< "\n";
    }
    return 0;
}

//Problem 4 --
//Print mirror  right angled triangle

#include<iostream>
using namespace std;
int main() {
	int n;
	cin>> n;
	
	for(int i=1; i<=n; i++) {
		for(int j=n-i; j>=1; j--) {
			cout << " ";
		}
		for(int k=1; k<=i; k++) {
			cout<< "*";
		}
		cout<<"\n";

	}
	return 0;
}


