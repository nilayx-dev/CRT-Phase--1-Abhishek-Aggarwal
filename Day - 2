//problem 3 -- If -else condition
//to verify user's age whther eligible for vote or not ?
#include<iostream>
using namespace std;
int main(){
    int age;
    cin>> age;
    
    if(age>=18){
        if(age>=100){
            cout<<"Eligible for vote(But we are super senior citizen";
        }else{
            cout<<"Eligible for vote";
        }
    }else{
        if(age<0){
            cout<<"Enter a valid age number";
        }else{
            cout<<"Not eligible for vote";
        }
    }
    return 0;
}

//Problem-4 -- Ternary operator
//Find the greater number among 2

#include<iostream>
using namespace std;

int main(){
    int a,b;
    int max_number;
    
    cin>> a>>b;
    //ternary operator
    max_number=(a>b) ? a:b;
    
    cout<< max_number;
    return 0;
}

//Problem 5 -- Continue Statement
//Print 1 to N and avoid these number which divisible by 3

#include<iostream>
using namespace std;

//Problem 5 -- Continue statement
//Print 1 to N and avoid these number which are divisible by3

int main(){
    int n;
    cin>> n;
    
    for(int i=0;i<=n;i++){
        if(i % 3 == 0){
            continue;
        }
        cout<< i<<" ";
    }
    cout<< "/n";
    return 0;
}


//Problem 6 -- Break statement
//We have to add numbers until we get a negative numbers

#include<iostream>
using namespace std;

int main(){
    int n;
    int sum = 0;
    
    while(true){
        cin>> n;
        
        if(n<0){
            break;
        }
        sum = sum+n;
    }
    cout<< sum;
    return 0;
}
