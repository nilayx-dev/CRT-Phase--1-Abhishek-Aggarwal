//Problem 1-- Inheritance
//Single Inheritance
class Vehicle{
  public:
  void Start(){
      cout<< "vehicle starts"<<"\n";
  }
};
class car:public Vehicle{
    public:
    void drive(){
        cout<<"car is running";
    }
};
int main(){
    car obj1;
    obj1.drive();
    obj1.Start();
}

//Problem 2-- Inheritance
//Multilevel Inheritance
class Vehicle{
  public:
  void Start(){
      cout<< "vehicle starts"<<"\n";
  }
};
class car:public Vehicle{
    public:
    void drive(){
        cout<<"car is running";
    }
};
class speedometer:public car{
    public:
    void speed(){
        cout<<"car is running at 60km/hr";
    }
};
int main(){
    speedometer obj1;
    obj1.speed();
    obj1.drive();
    obj1.Start();
}


//Problem 2-- Inheritance
//Hierarchial Inheritance
class Vehicle{
  public:
  void Start(){
      cout<< "vehicle starts"<<"\n";
  }
};
class car:public Vehicle{
    public:
    void drive(){
        cout<<"car is running";
    }
};
class Bike:public Vehicle{
    public:
    void speed(){
        cout<<"car is running at 60km/hr";
    }
};
int main(){
    Bike obj1;
    obj1.Start();
    obj1.speed();
    
    car obj2;
    obj2.drive();
}

//Problem 2-- Inheritance
//Multiple Inheritance
class Parent1{
  public:
  void giveMeMoney(){
      cout<< "Mummy paisa do mujhe"<<"\n";
  }
};
class Parent2{
    public:
    void giveMeMoney(){
        cout<<"papa paisa do mujhe";
    }
};
class Child:public Parent1,public Parent2{
};
int main(){
    Child obj1;
    obj1.Parent1::giveMeMoney();
    obj1.Parent2::giveMeMoney();
}

