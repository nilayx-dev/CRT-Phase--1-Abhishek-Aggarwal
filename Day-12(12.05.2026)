//Problem 1 --
//Print numbers 1 to 10 using recursion

#include<iostream>
using namespace std;
void printNumber(int n){
    if(n>10){
        return ;
    }
        cout<<n<<" ";

    printNumber(n+1);
}

int main(){
    printNumber(1);
}

//Problem 2--
//To find factorial of a numbers

#include<iostream>
using namespace std;

int factorial(int n){
    int fact;
    if(n==0 || n==1){
        return 1;
    }
    fact=n*factorial(n-1);
    return fact;
}

int main(){
    cout<<factorial(5);
    return 0;
}
